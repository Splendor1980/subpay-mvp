{
	"name": "@rialo/wallet-standard",
	"version": "0.1.1",
	"description": "Wallet Standard definition for Rialo Network",
	"keywords": [
		"wallet",
		"standard",
		"rialo",
		"wallet-standard",
		"blockchain",
		"web3",
		"crypto"
	],
	"homepage": "https://github.com/SubzeroLabs/wallet-standard#readme",
	"repository": "https://github.com/SubzeroLabs/wallet-standard.git",
	"license": "Apache-2.0",
	"author": "Subzero Labs <build@subzero.xyz>",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"check-types": "tsc --noEmit",
		"dev": "tsup --watch",
		"lint": "biome check src/",
		"lint:fix": "biome check --write src/",
		"prepack": "pnpm run build",
		"pack:dry": "npm pack --dry-run",
		"pack:test": "npm pack && tar -tzf *.tgz",
		"publish:dry": "npm publish --dry-run",
		"publish:local": "npm publish --registry http://localhost:4873/",
		"release:major": "npm version major && npm publish",
		"release:minor": "npm version minor && npm publish",
		"release:patch": "npm version patch && npm publish"
	},
	"dependencies": {
		"@wallet-standard/base": "1.1.0",
		"@wallet-standard/features": "1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.4",
		"tsup": "^8.5.1",
		"typescript": "5.9.3"
	},
	"packageManager": "pnpm@10.22.0",
	"engines": {
		"node": ">=18.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
