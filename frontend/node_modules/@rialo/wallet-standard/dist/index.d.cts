/**
 * Type representing a wallet that supports all Rialo features.
 * Use this type when you need a fully-featured Rialo wallet instance.
 *
 * @example
 * ```typescript
 * function useRialoWallet(wallet: WalletWithRialoFeatures): void {
 *   // TypeScript ensures all required features are available
 *   wallet.features["rialo:signMessage"].signMessage(...);
 *   wallet.features["rialo:signTransaction"].signTransaction(...);
 *   wallet.features["standard:connect"].connect();
 * }
 * ```
 */
type WalletWithRialoFeatures = WalletWithFeatures<RialoWalletRequiredFeatures>;

