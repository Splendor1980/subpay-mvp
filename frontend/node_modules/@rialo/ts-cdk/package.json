{
	"name": "@rialo/ts-cdk",
	"version": "0.11.2",
	"publishConfig": {
		"access": "public"
	},
	"description": "Rialo CDK - A comprehensive toolkit for building with the Rialo blockchain",
	"license": "Apache-2.0",
	"author": "Subzero Labs",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SubzeroLabs/rialo.git"
	},
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:vectors": "vitest run tests/*-vectors.test.ts",
		"test:coverage": "vitest --coverage",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"check": "biome check .",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build && npm run typecheck",
		"clean": "rm -rf node_modules dist"
	},
	"dependencies": {
		"@dao-xyz/borsh": "^5.2.4",
		"@noble/ciphers": "^1.3.0",
		"@noble/curves": "^2.0.1",
		"@noble/ed25519": "^3.0.0",
		"@noble/hashes": "2.0.0",
		"@scure/base": "^2.0.0",
		"@scure/bip32": "^2.0.1",
		"@scure/bip39": "^2.0.1",
		"ed25519-hd-key": "^1.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.10.5",
		"tsup": "^8.3.5",
		"tsx": "^4.20.6",
		"typescript": "^5.7.2",
		"vitest": "^4.0.4"
	},
	"keywords": [
		"rialo",
		"blockchain",
		"wallet",
		"transaction",
		"rpc",
		"cdk",
		"crypto"
	],
	"engines": {
		"node": ">=18.0.0"
	}
}
